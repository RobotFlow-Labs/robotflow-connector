# ── RobotFlow Connectors — Environment Configuration ──────────────
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit .env to version control!

# ── Default Provider ──────────────────────────────────────────────
# Which provider to use by default (claude, codex, minimax, glm5, kimi)
ROBOTFLOW_LLM_PROVIDER=minimax

# ── Global Settings (optional) ────────────────────────────────────
# ROBOTFLOW_SYSTEM_PROMPT="You are a helpful robot assistant."
# ROBOTFLOW_TEMPERATURE=0.7
# ROBOTFLOW_MAX_TOKENS=1024
# ROBOTFLOW_MAX_HISTORY=3

# ── Claude (Anthropic) ───────────────────────────────────────────
# Option A: API key (standard)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OAuth token (Claude Code / Claude Pro subscription)
# ANTHROPIC_OAUTH_TOKEN=your-oauth-bearer-token

# Option C: Web session key (fallback)
# CLAUDE_WEB_SESSION_KEY=sk-ant-sid...

# ── Codex / ChatGPT (OpenAI) ─────────────────────────────────────
# Option A: API key (standard)
# OPENAI_API_KEY=sk-...

# Option B: OAuth token (Codex / ChatGPT Plus subscription)
# OPENAI_OAUTH_TOKEN=your-oauth-bearer-token
# OPENAI_ACCOUNT_ID=acct-...

# ── MiniMax ───────────────────────────────────────────────────────
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ── GLM-5 (ZhipuAI) ──────────────────────────────────────────────
GLM5_API_KEY=your-glm5-api-key
GLM5_BASE_URL=https://api.z.ai/api/anthropic
GLM5_MODEL=glm-5

# ── Kimi (Moonshot) ──────────────────────────────────────────────
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.kimi.com/coding
KIMI_MODEL=kimi-for-coding
